msgid ""
"SmoothStep function( scalar(edge0), scalar(edge1), scalar(x) ).\n"
"\n"
"Returns 0.0 if 'x' is smaller than 'edge0' and 1.0 if x is larger than "
"'edge1'. Otherwise the return value is interpolated between 0.0 and 1.0 using "
"Hermite polynomials."
msgstr ""
"SmoothStep függvény ( skalár(edge0), skalár(edge1), skalár(x) ).\n"
"\n"
"Ha \"x\" kisebb, mint \"edge0\", akkor 0.0-t, ha \"x\" nagyobb, mint "
"\"edge1\", akkor 1.0-t ad vissza. Egyébként a visszaadott érték 0.0 és 1.0 "
"közé interpolálódik a Hermite polinomok használatával."

msgid ""
"Step function( scalar(edge), scalar(x) ).\n"
"\n"
"Returns 0.0 if 'x' is smaller than 'edge' and otherwise 1.0."
msgstr ""
"Step függvény ( skalár(edge), skalár(x) ).\n"
"\n"
"Ha \"x\" kisebb, mint \"edge\", akkor 0.0-t, egyébként 1.0-t ad vissza."

