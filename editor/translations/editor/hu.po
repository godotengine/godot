msgstr "3D vektor osztása 3D vektorral."

msgid "Divides 4D vector by 4D vector."
msgstr "4D vektor osztása 4D vektorral."

msgid "Multiplies 2D vector by 2D vector."
msgstr "2D vektor szorzása 2D vektorral."

