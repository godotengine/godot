msgstr "Lỗi: Dự án bị thiếu trên hệ thống tệp tin."

msgid "Toggle Favorite"
msgstr "Bật tắt Ưa thích"

msgid "Open in file manager"
msgstr "Mở trong trình quản lý tệp"

