msgstr "Không tìm thấy bản mẫu xuất debug: \"%s\"."

msgid "Release export template not found: \"%s\"."
msgstr "Không tìm thấy bản mẫu xuất release: \"%s\"."

msgid "Creating APK..."
msgstr "Đang tạo APK..."

msgid "Could not find template APK to export: \"%s\"."
msgstr "Không thể tìm bản mẫu APK để xuất: \"%s\"."

