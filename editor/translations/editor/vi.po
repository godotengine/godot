msgstr ""
"(Chỉ áp dụng trong chế độ Fragment/Light) (Vô hướng) Tính đạo hàm theo trục "
"'x' bằng phương pháp vi phân cục bộ."

msgid ""
"(Fragment/Light mode only) (Scalar) Derivative in 'y' using local "
"differencing."
msgstr ""
"(Chỉ áp dụng trong chế độ Fragment/Light) (Vô hướng) Tính đạo hàm theo trục "
"'y' bằng phương pháp vi phân cục bộ."

msgid "(Scalar) Derivative in 'x' using local differencing."
msgstr "(Vô hướng) Đạo hàm theo trục 'x' bằng phương pháp vi phân cục bộ."

