msgstr ""
"Đường dẫn Java SDK phải được cấu hình trong Cài đặt Trình biên tập tại mục "
"'export/android/java_sdk_path'."

msgid ""
"Android SDK path must be configured in Editor Settings at 'export/android/"
"android_sdk_path'."
msgstr ""
"Đường dẫn Android SDK phải được cấu hình trong Cài đặt Trình biên tập tại mục "
"'export/android/android_sdk_path'."

msgid "Unable to overwrite res/*.xml files with project name."
msgstr "Không thể ghi đè các tệp res/*.xml với tên dự án."

msgid "Could not generate sparse pck metadata!"
msgstr "Không thể tạo siêu dữ liệu PCK thưa!"

msgid "Could not write PCK directory!"
msgstr "Không thể ghi thư mục PCK!"

msgid "Could not export project files to gradle project."
msgstr "Không thể xuất các tệp dự án sang dự án Gradle."

msgid "Failed to copy debug keystore to temp directory."
msgstr "Không thể sao chép keystore debug vào thư mục tạm."

msgid "Failed to copy release keystore to temp directory."
msgstr "Không thể sao chép keystore release vào thư mục tạm."

msgid "Building of Android project failed, check output for the error:"
msgstr "Xây dựng dự án Android thất bại, hãy kiểm tra đầu ra để biết lỗi:"

