msgstr "Không thể tải dự án ở '%s' (lỗi %d). Nó có thể đã bị mất hoặc bị hỏng."

msgid "Couldn't save project at '%s' (error %d)."
msgstr "Không thể lưu dự án tại '%s' (lỗi %d)."

