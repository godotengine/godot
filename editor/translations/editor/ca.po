msgstr "Estableix la vista prèvia de l'altitud del sol"

msgid "Set Preview Sun Azimuth"
msgstr "Estableix la vista prèvia de l'azimut del sol"

msgid "Set Preview Sun Color"
msgstr "Estableix la vista prèvia del color del sol"

msgid "Set Preview Sun Energy"
msgstr "Estableix la vista prèvia de l'energia solar"

