        "core/psa_crypto_driver_wrappers_no_static.c",
    ]

    psa_dir = "#thirdparty/mbedtls/tf-psa-crypto/"
    psa_sources = [psa_dir + file for file in psa_sources]
    env_psa.Prepend(CPPPATH=[psa_dir + "drivers/builtin/src/"])
    env_psa.Prepend(CPPPATH=[psa_dir + "platform/"])
    env_psa.Prepend(CPPPATH=[psa_dir + "utilities/"])
    env_psa.Prepend(CPPPATH=[psa_dir + "extras/"])
    env_psa.Prepend(CPPPATH=[psa_dir + "dispatch/"])
    env_psa.Prepend(CPPPATH=[psa_dir + "core/"])
    env_psa.disable_warnings()
    env_psa.add_source_files(psa_obj, psa_sources)
    env_psa.Depends(psa_obj, configs)
    env.modules_sources += psa_obj

    # mbedTLS
    mbedtls_sources = [
        # mbedx509
        "library/error.c",
        "library/mbedtls_config.c",
        "library/pkcs7.c",
        "library/x509.c",
        "library/x509_create.c",
        "library/x509_crl.c",
        "library/x509_crt.c",
        "library/x509_csr.c",
        "library/x509_oid.c",
        "library/x509write.c",
        "library/x509write_crt.c",
        "library/x509write_csr.c",
        # mbedtls
        "library/debug.c",
        "library/mps_reader.c",
        "library/mps_trace.c",
        "library/net_sockets.c",
        "library/ssl_cache.c",
        "library/ssl_ciphersuites.c",
