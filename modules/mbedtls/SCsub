        # Extras
        "extras/lmots.c",
        "extras/lms.c",
        "extras/md.c",
        "extras/nist_kw.c",
        "extras/pk.c",
        "extras/pk_ecc.c",
        "extras/pk_rsa.c",
        "extras/pk_wrap.c",
        "extras/pkparse.c",
        "extras/pkwrite.c",
        # Platform
        "platform/memory_buffer_alloc.c",
        "platform/platform.c",
        "platform/platform_util.c",
        "platform/threading.c",
        # Utilities
        "utilities/asn1parse.c",
        "utilities/asn1write.c",
        "utilities/base64.c",
        "utilities/constant_time.c",
        "utilities/oid.c",
        "utilities/pem.c",
        "utilities/pkcs5.c",
        # Core
        "core/psa_crypto.c",
        "core/psa_crypto_client.c",
        "core/psa_crypto_random.c",
        "core/psa_crypto_slot_management.c",
