  <!-- In-process Godot engine (built from UWP_Export\godot with
       library_type=shared_library) plus the D3D12 Agility SDK runtime,
       deployed to the appx package root. -->
  <ItemGroup>
    <Content Include="..\..\..\..\bin\godot.windows.template_release.x86_64.dll">
      <Link>godot.dll</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\bin\D3D12Core.dll">
      <Link>D3D12Core.dll</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\bin\d3d12SDKLayers.dll">
      <Link>d3d12SDKLayers.dll</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <!-- Preferred payload: a single exported .pck. One opaque file avoids the
         MRT resource indexer misparsing project sub-paths as resource
         qualifiers (0x80073B0C) and the MAX_PATH/DEP1000 layout-copy issue. -->
    <Content Include="Assets\project.pck" Condition="Exists('Assets\project.pck')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <!-- Fallback payload (when no .pck is present): the loose Godot project
         folder, excluding editor caches whose hashed paths exceed MAX_PATH
         during AppX layout copy (DEP1000) and any export build dir.
         .godot\imported MUST stay: the engine reads imported resources from
         it when running in project-dir mode. -->
    <Content Include="GodotProject\**\*" Condition="!Exists('Assets\project.pck')" Exclude="GodotProject\.godot\shader_cache\**;GodotProject\.godot\editor\**;GodotProject\.godot\exported\**;GodotProject\build\**;GodotProject\**\~*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
