msgid "If [code]true[/code], the TreeItem is collapsed."
msgstr "[code]true[/code]이면 TreeItem이 접힙니다."

msgid "If [code]true[/code], folding is disabled for this TreeItem."
msgstr "[code]true[/code]이면 이 TreeItem에 대해 접기가 비활성화됩니다."

msgid "Invalid gateway."
msgstr "잘못된 게이트웨이."

msgid "Unknown error."
msgstr "알 수 없는 오류."

msgid "OK."
msgstr "양호."

msgid "Disconnected."
msgstr "연결 해제됨."

msgid "A container that arranges its child controls vertically."
msgstr "자식 컨트롤을 세로로 배열하는 컨테이너."

msgid "Returns [code]true[/code] if the vectors are not equal."
msgstr "벡터가 동일하지 않으면 [code]true[/code]를 반환합니다."

