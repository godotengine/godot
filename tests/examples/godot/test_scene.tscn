script/source = "extends Node3D

# Simple test script to add GaussianSplatRenderer to the scene
func _ready():
	print('[Test Scene] Creating GaussianSplatRenderer...')

	# Create the Gaussian Splat Renderer
	var gaussian_renderer = GaussianSplatRenderer.new()
	add_child(gaussian_renderer)

	# Position camera to view the splats
	var camera = get_viewport().get_camera_3d()
	if camera:
		camera.position = Vector3(0, 0, 10)
		camera.look_at(Vector3.ZERO, Vector3.UP)

	print('[Test Scene] GaussianSplatRenderer added successfully!')
"

