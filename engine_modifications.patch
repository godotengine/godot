+    header_data.fragment_lines = _sanitize_glsl_lines(header_data.fragment_lines)
+    header_data.compute_lines = _sanitize_glsl_lines(header_data.compute_lines)
     class_name = os.path.basename(shader).replace(".glsl", "").title().replace("_", "").replace(".", "") + "ShaderRD"
 
