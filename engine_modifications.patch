+def _sanitize_glsl_lines(lines: List[str]) -> List[str]:
+    sanitized: List[str] = []
+    for line in lines:
+        stripped = line.strip()
+        if stripped.startswith("#extension"):
+            if "GL_KHR_vulkan_glsl" in stripped or "GL_GOOGLE_include_directive" in stripped:
+                # Godot's RenderingDevice GLSL compiler rejects these directives. The
+                # include directive is redundant because includes are resolved by the
+                # builder and the Vulkan GLSL directive is unnecessary for SPIR-V
+                # generation. Skip them to keep the resulting shader portable.
+                continue
+        sanitized.append(line)
+    return sanitized
+
+
