+void SceneTreeDock::_perform_create_gaussian_splats(const Vector<String> &p_files, Node *p_parent, int p_pos) {
+	ERR_FAIL_NULL(p_parent);
+
+	Vector<Node *> nodes;
+
+	for (const String &path : p_files) {
+		GaussianSplatNode3D *splat_node = memnew(GaussianSplatNode3D);
+		String node_name = Node::adjust_name_casing(path.get_file().get_basename());
+		if (!node_name.is_empty()) {
+			splat_node->set_name(node_name);
+		}
+
+		String resource_path = ProjectSettings::get_singleton()->localize_path(path);
+		splat_node->set_ply_file_path(resource_path);
+		splat_node->set_auto_load(true);
+
+		nodes.push_back(splat_node);
+	}
+
+	if (nodes.is_empty()) {
+		return;
+	}
+
+	EditorUndoRedoManager *undo_redo = EditorUndoRedoManager::get_singleton();
+	undo_redo->create_action_for_history(TTRN("Create Gaussian Splat", "Create Gaussian Splats", nodes.size()), editor_data->get_current_edited_scene_history_id());
+	undo_redo->add_do_method(editor_selection, "clear");
+
+	for (int i = 0; i < nodes.size(); i++) {
+		Node *node = nodes[i];
+		undo_redo->add_do_method(p_parent, "add_child", node, true);
+		if (p_pos >= 0) {
+			undo_redo->add_do_method(p_parent, "move_child", node, p_pos + i);
+		}
+		undo_redo->add_do_method(node, "set_owner", edited_scene);
+		undo_redo->add_do_method(editor_selection, "add_node", node);
+		undo_redo->add_do_reference(node);
+		undo_redo->add_undo_method(p_parent, "remove_child", node);
+
+		EditorDebuggerNode *ed = EditorDebuggerNode::get_singleton();
+		undo_redo->add_do_method(ed, "live_debug_create_node", edited_scene->get_path_to(p_parent), node->get_class(), node->get_name());
+		undo_redo->add_undo_method(ed, "live_debug_remove_node", NodePath(String(edited_scene->get_path_to(p_parent)).path_join(node->get_name())));
+	}
+
+	undo_redo->commit_action();
+
+	if (!nodes.is_empty()) {
+		_push_item(nodes[nodes.size() - 1]);
+		for (Node *node : nodes) {
+			emit_signal(SNAME("node_created"), node);
+		}
+	}
+}
